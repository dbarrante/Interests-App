{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/guard.js"],
            "timeout": 15,
            "statusMessage": "Personal-data guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/post-edit.js"],
            "timeout": 60,
            "statusMessage": "Syntax gate"
          }
        ]
      }
    ]
  }
}
