{
  "manifest_version": 3,
  "name": "Interests Capture",
  "version": "3.8",
  "description": "Captures screenshots and metadata for the Interests App",
  "permissions": ["scripting", "tabs", "storage", "notifications", "webNavigation", "webRequest", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "http://127.0.0.1:*/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["fb-save.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Interests Capture",
    "default_popup": "popup.html"
  }
}
