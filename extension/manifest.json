{
  "manifest_version": 3,
  "name": "Interests Capture",
  "version": "4.54",
  "description": "Captures screenshots and metadata for the Interests App",
  "options_page": "options.html",
  "permissions": ["scripting", "tabs", "storage", "unlimitedStorage", "notifications", "webNavigation", "contextMenus", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.pinterest.com/*",
        "*://*.pinterest.ca/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.com.au/*",
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": ["yt-save-trigger.js", "capture-configs.js", "capture-core.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Stumble",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
