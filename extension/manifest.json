{
  "manifest_version": 3,
  "name": "Interests Capture",
  "version": "4.46",
  "description": "Captures screenshots and metadata for the Interests App",
  "permissions": ["scripting", "tabs", "storage", "unlimitedStorage", "notifications", "webNavigation", "webRequest", "contextMenus", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3456/*", "http://localhost:3457/*", "http://localhost:3458/*", "http://localhost:3459/*", "http://localhost:3460/*",
        "http://localhost:3461/*", "http://localhost:3462/*", "http://localhost:3463/*", "http://localhost:3464/*", "http://localhost:3465/*",
        "http://127.0.0.1:3456/*", "http://127.0.0.1:3457/*", "http://127.0.0.1:3458/*", "http://127.0.0.1:3459/*", "http://127.0.0.1:3460/*",
        "http://127.0.0.1:3461/*", "http://127.0.0.1:3462/*", "http://127.0.0.1:3463/*", "http://127.0.0.1:3464/*", "http://127.0.0.1:3465/*"
      ],
      "js": ["bridge-probe.js", "bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.pinterest.com/*",
        "*://*.pinterest.ca/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.com.au/*",
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": ["yt-save-trigger.js", "capture-configs.js", "capture-core.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Interests Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
